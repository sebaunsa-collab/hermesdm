# HermesDM — Environment Variables
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# MiniMax API Key (for image generation + LLM narration)
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY_HERE

# Optional: Restrict bot to a specific Telegram group ID.
# Leave empty to allow the bot in any chat (DMs and groups).
# To find your group ID: add @userinfobot or @getidsbot to the group.
# ALLOWED_GROUP_ID=-1001234567890

# Optional: Custom campaign storage directory
# HERMESDM_DATA_DIR=~/.hermes/hermesdm

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
