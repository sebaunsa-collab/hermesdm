"""
state_manager.py — Campaign state persistence.
Saves/loads world state as JSON in ~/.hermes/hermesdm/campaigns/{id}/state.json
"""

from __future__ import annotations

import json
from pathlib import Path
from typing import TYPE_CHECKING

from campaign_settings import CampaignSettings

if TYPE_CHECKING:
    from state.npc_store import NPCRecord, NPCStore

# Runtime imports — needed by load_npc_store / save_npc_store / add_npc_to_state
from state.npc_store import NPCStore, NPCRecord

CAMPAIGNS_DIR = Path.home() / ".hermes" / "hermesdm" / "campaigns"


def _ensure_dir(campaign_id: str) -> Path:
    campaign_dir = CAMPAIGNS_DIR / campaign_id
    campaign_dir.mkdir(parents=True, exist_ok=True)
    return campaign_dir


def _state_path(campaign_id: str) -> Path:
    return _ensure_dir(campaign_id) / "state.json"


def new_state(campaign_id: str, name: str, setting: str) -> dict:
    """
    Create a fresh campaign state.
    """
    from datetime import datetime as _dt

    state = {
        "campaign": {
            "id": campaign_id,
            "name": name,
            "setting": setting,
            "created": _dt.utcnow().isoformat(),
            "current_location": None,
            "status": "setup",
            "completed_at": None,
            "epilogue": None,
            "image_provider": "pollinations",
        },
        "setup": {
            "description": "",
            "classes": None,
            "premise": "",
            "hook": "",
            "tone": "serious",
            "setting_type": setting,
            "created": _dt.utcnow().isoformat(),
            "approved": False,
            "lore": {
                "factions": {},
                "main_threat": "",
                "starting_location": "",
                "starting_location_desc": "",
                "npcs": {},
            },
        },
        "world": {},
        "npcs": {},
        "characters": {},
        "combat": {"active": False, "round": 0, "initiative": [], "current_turn": None, "per_round_flags": {"action": False, "bonus": False, "reaction": False, "movement": False}},
        "quests": {"active": [], "completed": []},
        "history": [],
        "generated_images": [],
        "story_arc": None,
        "world_flags": {},
        "use_character_progression": True,
        "use_scene_director": True,
        "use_content_engine": True,
        "dungeon": None,
        "player": {
            "xp_current": 0,
            "level": 1,
            "proficiency_bonus": 2,
            "features": [],
            "active_effects": [],
            "spell_slots": {"max": [0] * 9, "used": [0] * 9},
        },
        "settings": CampaignSettings().to_dict(),
    }
    return state


def save_state(campaign_id: str, state: dict) -> None:
    """
    Persist state to JSON file. Creates campaign dir if needed.
    """
    path = _state_path(campaign_id)
    with open(path, "w", encoding="utf-8") as f:
        json.dump(state, f, indent=2, ensure_ascii=False)


def load_state(campaign_id: str) -> dict | None:
    """
    Load campaign state from JSON. Returns None if not found.
    """
    path = _state_path(campaign_id)
    if not path.exists():
        return None
    with open(path, encoding="utf-8") as f:
        return json.load(f)


def campaign_exists(campaign_id: str) -> bool:
    return _state_path(campaign_id).exists()


def list_campaigns() -> list[dict]:
    campaigns = []
    if not CAMPAIGNS_DIR.exists():
        return campaigns

    for campaign_dir in CAMPAIGNS_DIR.iterdir():
        if campaign_dir.is_dir():
            state_file = campaign_dir / "state.json"
            if state_file.exists():
                try:
                    with open(state_file, encoding="utf-8") as f:
                        data = json.load(f)
                    campaigns.append(
                        {
                            "id": data.get("campaign", {}).get("id", campaign_dir.name),
                            "name": data.get("campaign", {}).get("name", "Unnamed"),
                            "setting": data.get("campaign", {}).get(
                                "setting", "unknown"
                            ),
                        }
                    )
                except Exception:
                    campaigns.append(
                        {
                            "id": campaign_dir.name,
                            "name": "Unnamed",
                            "setting": "unknown",
                        }
                    )

    campaigns.sort(key=lambda x: x["id"], reverse=True)
    return campaigns


def apply_world_change(campaign_id: str, key_path: str, value) -> dict:
    """
    Apply a world state change.
    key_path like "npcs.captain_vorn.status" or "world.main_threat"
    Returns updated state.
    """
    state = load_state(campaign_id)
    if state is None:
        raise ValueError(f"Campaign {campaign_id} not found")

    parts = key_path.split(".")
    current = state
    for part in parts[:-1]:
        if part not in current:
            current[part] = {}
        current = current[part]
    current[parts[-1]] = value

    save_state(campaign_id, state)
    return state


def get_settings(campaign_id: str) -> CampaignSettings:
    state = load_state(campaign_id)
    if state is None:
        return CampaignSettings()
    settings_data = state.get("settings", {})
    return CampaignSettings.from_dict(settings_data)


def update_settings(
    campaign_id: str, key: str, value: str
) -> tuple[bool, str, CampaignSettings]:
    state = load_state(campaign_id)
    if state is None:
        return False, f"Campaign {campaign_id} not found", CampaignSettings()

    settings = CampaignSettings.from_dict(state.get("settings", {}))
    success, message = settings.apply_update(key, value)
    if success:
        state["settings"] = settings.to_dict()
        save_state(campaign_id, state)

    return success, message, settings


# ── NPC Persistence Helpers ─────────────────────────────────────────────────

def load_npc_store(campaign_id: str) -> NPCStore:
    state = load_state(campaign_id)
    if state is None:
        return NPCStore()
    return NPCStore.from_dict(state.get("npcs", {}))


def save_npc_store(campaign_id: str, store: NPCStore) -> None:
    state = load_state(campaign_id)
    if state is None:
        return
    state["npcs"] = store.to_dict()
    save_state(campaign_id, state)


def add_npc_to_state(campaign_id: str, npc_record: NPCRecord) -> None:
    store = load_npc_store(campaign_id)
    store.add(npc_record)
    save_npc_store(campaign_id, store)


def remove_npc_from_state(campaign_id: str, npc_id: str) -> bool:
    store = load_npc_store(campaign_id)
    result = store.remove(npc_id)
    if result:
        save_npc_store(campaign_id, store)
    return result


# ── NPC Memory & World Continuity ────────────────────────────────────────────

def add_npc_memory(
    campaign_id: str,
    npc_id: str,
    memory_entry: str,
) -> tuple[bool, str]:
    from state.state_validator import add_npc_memory as _sv_add
    state = load_state(campaign_id)
    return _sv_add(campaign_id, npc_id, memory_entry, state)


def get_world_summary(campaign_id: str) -> str:
    from dm.world_builder import get_world_summary as _wb_summary
    return _wb_summary(campaign_id)


# ── ChatState → state.json sync helpers ──────────────────────────────────────

def sync_chatstate_to_state(campaign_id: str, cs) -> dict | None:
    state = load_state(campaign_id)
    if state is None:
        return None

    # ── Characters ────────────────────────────────────────────────────────────
    state["characters"] = {}
    for key, char in cs.characters.items():
        char_dict = char.to_dict()
        char_dict["player_id"] = key
        state["characters"][key] = char_dict

    # ── Combat state ──────────────────────────────────────────────────────────
    if cs.combat_state is not None:
        combatants_data = []
        for c in cs.combat_state.initiative_order:
            combatants_data.append({
                "name": c.name,
                "initiative": c.initiative,
                "is_player": c.is_player,
                "is_active": c.is_active,
                "delayed": c.delayed,
                "held": c.held,
            })
        state["combat"] = {
            "active": cs.combat_state.active,
            "round": cs.combat_state.round,
            "initiative_order": combatants_data,
            "current_index": cs.combat_state.current_index,
            "current_turn": cs.combat_state.current_turn,
        }
    else:
        state["combat"] = {
            "active": False,
            "round": 0,
            "initiative_order": [],
            "current_index": 0,
            "current_turn": None,
        }

    save_state(campaign_id, state)
    return state


def set_world_flag(
    campaign_id: str,
    flag_name: str,
    value: bool,
) -> bool:
    state = load_state(campaign_id)
    if state is None:
        return False

    if "world_flags" not in state:
        state["world_flags"] = {}

    current = state["world_flags"].get(flag_name, False)

    if current and not value:
        import logging
        logging.getLogger(__name__).warning(
            f"Attempted to flip flag '{flag_name}' from True to False "
            f"in campaign {campaign_id}. Rejected."
        )
        return False

    state["world_flags"][flag_name] = value
    save_state(campaign_id, state)
    return True


def check_world_flag(
    campaign_id: str,
    flag_name: str,
) -> bool:
    state = load_state(campaign_id)
    if state is None:
        return False

    world_flags = state.get("world_flags", {})
    return world_flags.get(flag_name, False)


def append_history(
    campaign_id: str,
    event_text: str,
    entry_type: str = "narration",
    session: int | None = None,
) -> bool:
    state = load_state(campaign_id)
    if state is None:
        return False

    from datetime import datetime as _dt

    entry = {
        "event": event_text,
        "type": entry_type,
        "timestamp": _dt.utcnow().isoformat(),
    }
    if session is not None:
        entry["session"] = session

    if "history" not in state:
        state["history"] = []
    state["history"].append(entry)

    save_state(campaign_id, state)
    return True


# ── Character Progression helpers ────────────────────────────────────────────

def add_xp(campaign_id: str, xp_amount: int) -> dict:
    """Add XP to the player character and process level-ups.

    Returns award_xp result dict with levels_gained and messages.
    """
    from dm.xp_engine import award_xp

    state = load_state(campaign_id)
    if state is None:
        return {"error": f"Campaign {campaign_id} not found"}

    player = state.setdefault("player", {})
    result = award_xp(player, xp_amount)
    player.update(result["character"])

    # Grant class features for new levels
    if result["levels_gained"]:
        class_name = player.get("player_class",
                               state.get("characters", {}).get("player_id", {}).get("class", "fighter"))
        from dm.class_features import grant_features_at_level
        for lvl in result["levels_gained"]:
            new_feats = grant_features_at_level(class_name, lvl)
            player.setdefault("features", []).extend(new_feats)

    # Update spell slots for new level if caster
    if result["levels_gained"]:
        new_level = player["level"]
        from dm.spell_engine import get_spell_slots, CASTER_TYPE_MAP
        caster_type = CASTER_TYPE_MAP.get(class_name, "none")
        if caster_type != "none":
            new_slots = get_spell_slots(new_level, caster_type)
            max_slots = [new_slots.get(i, 0) for i in range(1, 10)]
            player.setdefault("spell_slots", {"max": [0]*9, "used": [0]*9})["max"] = max_slots

    save_state(campaign_id, state)
    return result


def set_level(campaign_id: str, new_level: int) -> bool:
    """Set player character level directly (DM fiat)."""
    state = load_state(campaign_id)
    if state is None:
        return False
    player = state.setdefault("player", {})
    player["level"] = max(1, min(new_level, 20))
    from dm.xp_engine import PROFICIENCY_BONUS
    player["proficiency_bonus"] = PROFICIENCY_BONUS.get(player["level"], 2)
    save_state(campaign_id, state)
    return True


if __name__ == "__main__":
    print("=== state_manager sanity test ===")
    state = new_state("test_001", "Test Campaign", "fantasy")
    print(f"New state created: {state['campaign']['id']}")
    print(f"Progression flag: {state.get('use_character_progression')}")
    print(f"Player level: {state.get('player', {}).get('level')}")
    print(f"Player features: {len(state.get('player', {}).get('features', []))}")

    save_state("test_001", state)
    loaded = load_state("test_001")
    print(f"Loaded: {loaded['campaign']['name']}")
    print(f"Campaigns: {list_campaigns()}")
